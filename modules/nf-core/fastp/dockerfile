# First stage: Download and verify fastp binary
FROM ubuntu:22.04
ARG FASTP_VERSION=1.3.3

WORKDIR /usr/local/bin/

# Use Aliyun mirror and install dependencies
RUN sed -i 's/archive.ubuntu.com/mirrors.aliyun.com/g' /etc/apt/sources.list && \
    sed -i 's/security.ubuntu.com/mirrors.aliyun.com/g' /etc/apt/sources.list && \
    sed -i 's/ports.ubuntu.com/mirrors.aliyun.com/g' /etc/apt/sources.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends wget ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Download PRECOMPILED binary (not source code) from GitHub Releases
RUN wget http://opengene.org/fastp/fastp && \
    chmod a+x ./fastp  # Ensure executable permission

# Copy the binary from downloader stage
# COPY --from=downloader /opt/fastp /usr/local/bin/

# Default execution
# ENTRYPOINT ["fastp"]
CMD ["fastp"]
